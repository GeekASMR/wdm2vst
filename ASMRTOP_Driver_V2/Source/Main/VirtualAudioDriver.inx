;======================================================
; ASMRTOPVirtualAudio_SA  (NT Install)
;======================================================
[ASMRTOPVirtualAudio_SA.NT]
Include=ks.inf,wdmaudio.inf
Needs=KS.Registration, WDMAUDIO.Registration
CopyFiles=ASMRTOPVirtualAudio_SA.CopyList
AddReg=ASMRTOPVirtualAudio_SA.AddReg

[ASMRTOPVirtualAudio_SA.NT.Interfaces]
;
; Render endpoints: Speaker 1-4
;
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveSpeaker%,     ASMRTOPVirtualAudio.I.WaveSpeaker
AddInterface=%KSCATEGORY_RENDER%,   %KSNAME_WaveSpeaker%,     ASMRTOPVirtualAudio.I.WaveSpeaker
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveSpeaker%,     ASMRTOPVirtualAudio.I.WaveSpeaker
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologySpeaker%, ASMRTOPVirtualAudio.I.TopologySpeaker
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologySpeaker%, ASMRTOPVirtualAudio.I.TopologySpeaker

AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveSpeaker2%,     ASMRTOPVirtualAudio.I.WaveSpeaker2
AddInterface=%KSCATEGORY_RENDER%,   %KSNAME_WaveSpeaker2%,     ASMRTOPVirtualAudio.I.WaveSpeaker2
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveSpeaker2%,     ASMRTOPVirtualAudio.I.WaveSpeaker2
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologySpeaker2%, ASMRTOPVirtualAudio.I.TopologySpeaker2
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologySpeaker2%, ASMRTOPVirtualAudio.I.TopologySpeaker2

AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveSpeaker3%,     ASMRTOPVirtualAudio.I.WaveSpeaker3
AddInterface=%KSCATEGORY_RENDER%,   %KSNAME_WaveSpeaker3%,     ASMRTOPVirtualAudio.I.WaveSpeaker3
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveSpeaker3%,     ASMRTOPVirtualAudio.I.WaveSpeaker3
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologySpeaker3%, ASMRTOPVirtualAudio.I.TopologySpeaker3
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologySpeaker3%, ASMRTOPVirtualAudio.I.TopologySpeaker3

AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveSpeaker4%,     ASMRTOPVirtualAudio.I.WaveSpeaker4
AddInterface=%KSCATEGORY_RENDER%,   %KSNAME_WaveSpeaker4%,     ASMRTOPVirtualAudio.I.WaveSpeaker4
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveSpeaker4%,     ASMRTOPVirtualAudio.I.WaveSpeaker4
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologySpeaker4%, ASMRTOPVirtualAudio.I.TopologySpeaker4
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologySpeaker4%, ASMRTOPVirtualAudio.I.TopologySpeaker4

;
; Capture endpoints: MicArray 1-4
;
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveMicArray1%,     ASMRTOPVirtualAudio.I.WaveMicArray1
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveMicArray1%,     ASMRTOPVirtualAudio.I.WaveMicArray1
AddInterface=%KSCATEGORY_CAPTURE%,  %KSNAME_WaveMicArray1%,     ASMRTOPVirtualAudio.I.WaveMicArray1
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologyMicArray1%, ASMRTOPVirtualAudio.I.TopologyMicArray1
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologyMicArray1%, ASMRTOPVirtualAudio.I.TopologyMicArray1

AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveMicArray2%,     ASMRTOPVirtualAudio.I.WaveMicArray2
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveMicArray2%,     ASMRTOPVirtualAudio.I.WaveMicArray2
AddInterface=%KSCATEGORY_CAPTURE%,  %KSNAME_WaveMicArray2%,     ASMRTOPVirtualAudio.I.WaveMicArray2
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologyMicArray2%, ASMRTOPVirtualAudio.I.TopologyMicArray2
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologyMicArray2%, ASMRTOPVirtualAudio.I.TopologyMicArray2

AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveMicArray3%,     ASMRTOPVirtualAudio.I.WaveMicArray3
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveMicArray3%,     ASMRTOPVirtualAudio.I.WaveMicArray3
AddInterface=%KSCATEGORY_CAPTURE%,  %KSNAME_WaveMicArray3%,     ASMRTOPVirtualAudio.I.WaveMicArray3
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologyMicArray3%, ASMRTOPVirtualAudio.I.TopologyMicArray3
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologyMicArray3%, ASMRTOPVirtualAudio.I.TopologyMicArray3

AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_WaveMicArray4%,     ASMRTOPVirtualAudio.I.WaveMicArray4
AddInterface=%KSCATEGORY_REALTIME%, %KSNAME_WaveMicArray4%,     ASMRTOPVirtualAudio.I.WaveMicArray4
AddInterface=%KSCATEGORY_CAPTURE%,  %KSNAME_WaveMicArray4%,     ASMRTOPVirtualAudio.I.WaveMicArray4
AddInterface=%KSCATEGORY_AUDIO%,    %KSNAME_TopologyMicArray4%, ASMRTOPVirtualAudio.I.TopologyMicArray4
AddInterface=%KSCATEGORY_TOPOLOGY%, %KSNAME_TopologyMicArray4%, ASMRTOPVirtualAudio.I.TopologyMicArray4

[ASMRTOPVirtualAudio_SA.NT.Services]
AddService=ASMRTOPVirtualAudio,0x00000002,ASMRTOPVirtualAudio_Service_Inst

[ASMRTOPVirtualAudio_Service_Inst]
DisplayName=%ASMRTOPVirtualAudio.SvcDesc%
ServiceType=1
StartType=3
ErrorControl=1
ServiceBinary=%13%\VirtualAudioDriver.sys

[ASMRTOPVirtualAudio_SA.NT.HW]
AddReg = AUDIOHW.AddReg

[AUDIOHW.AddReg]
; FILE_DEVICE_SOUND
HKR,,DeviceType,0x10001,0x0000001D
; SDDL_DEVOBJ_SYS_ALL_ADM_RWX_WORLD_RWX_RES_RWX
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GRGWGX;;;BA)(A;;GRGWGX;;;WD)(A;;GRGWGX;;;RC)"

;======================================================
; WDF
;======================================================
[ASMRTOPVirtualAudio_SA.NT.Wdf]
KmdfService = ASMRTOPVirtualAudio, ASMRTOPVirtualAudio_SA_WdfSect
[ASMRTOPVirtualAudio_SA_WdfSect]
KmdfLibraryVersion = $KMDFVERSION$

