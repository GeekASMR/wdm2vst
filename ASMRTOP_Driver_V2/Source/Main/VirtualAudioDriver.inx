[Version]
Signature   = "$Windows NT$"
Class       = MEDIA
Provider    = %ProviderName%
ClassGUID   = {4d36e96c-e325-11ce-bfc1-08002be10318}
DriverVer   = 02/22/2016, 1.0.0.1
CatalogFile = ASMRTOPVirtualAudio.cat
PnpLockDown = 1

[SourceDisksNames]
222="ASMRTOPVirtualAudio Driver Disk","",222

[SourceDisksFiles]
VirtualAudioDriver.sys=222

[SignatureAttributes]
VirtualAudioDriver.sys=SignatureAttributes.DRM

[SignatureAttributes.DRM]
DRMLevel=1300

[SignatureAttributes.PETrust]
PETrust=true

[Manufacturer]
%MfgName%=ASMRTOPVirtualAudio,NT$ARCH$.10.0...16299

[ASMRTOPVirtualAudio.NT$ARCH$.10.0...16299]
%ASMRTOPVirtualAudio_SA.DeviceDesc%=ASMRTOPVirtualAudio_SA, ROOT\ASMRTOPVirtualAudio

[DestinationDirs]
ASMRTOPVirtualAudio_SA.CopyList=13

;======================================================
; ASMRTOPVirtualAudio_SA
;======================================================
[ASMRTOPVirtualAudio_SA.CopyList]
VirtualAudioDriver.sys

[ASMRTOPVirtualAudio_SA.AddReg]
HKR,,AssociatedFilters,,"wdmaud,swmidi,redbook"
HKR,,Driver,,VirtualAudioDriver.sys

;
; Power management settings
;
HKR,PowerSettings,SingleComponentMultiFxStates,3,1,0,0,0
HKR,PowerSettings,ConservationIdleTime,3,3,0,0,0
HKR,PowerSettings,PerformanceIdleTime,3,3,0,0,0
HKR,PowerSettings,IdlePowerState,3,3,0,0,0

HKR,Drivers,SubClasses,,"wave,midi,mixer"

HKR,Drivers\wave\wdmaud.drv,Driver,,wdmaud.drv
HKR,Drivers\midi\wdmaud.drv,Driver,,wdmaud.drv
HKR,Drivers\mixer\wdmaud.drv,Driver,,wdmaud.drv

HKR,Drivers\wave\wdmaud.drv,Description,,%ASMRTOPVirtualAudio_SA.DeviceDesc%
HKR,Drivers\mixer\wdmaud.drv,Description,,%ASMRTOPVirtualAudio_SA.DeviceDesc%

;======================================================
; Render interfaces: Speaker 1
;======================================================
[ASMRTOPVirtualAudio.I.WaveSpeaker]
AddReg=ASMRTOPVirtualAudio.I.WaveSpeaker.AddReg
[ASMRTOPVirtualAudio.I.WaveSpeaker.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ASMRTOPVirtualAudio.WaveSpeaker.szPname%

[ASMRTOPVirtualAudio.I.TopologySpeaker]
AddReg=ASMRTOPVirtualAudio.I.TopologySpeaker.AddReg, OEMSpeaker1.AddReg
[ASMRTOPVirtualAudio.I.TopologySpeaker.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ASMRTOPVirtualAudio.TopologySpeaker.szPname%

[OEMSpeaker1.AddReg]
HKR,EP\0,%PKEY_AudioEndpoint_Association%,,%KSNODETYPE_LINE_CONNECTOR%
HKR,EP\0,%PKEY_AudioEndpoint_Supports_EventDriven_Mode%,0x00010001,0x1
HKR,EP\0,%PKEY_Device_DeviceDesc%,,%SpeakerName1%

